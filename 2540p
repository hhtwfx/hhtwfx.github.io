# 最小可引导内核（HP 2540p 专用）
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_X86=y
CONFIG_MMU=y
CONFIG_ACPI=y
CONFIG_ACPI_AC=y
CONFIG_ACPI_BATTERY=y
CONFIG_ACPI_BUTTON=y
CONFIG_ACPI_VIDEO=y
CONFIG_ACPI_FAN=y
CONFIG_ACPI_PROCESSOR=y
CONFIG_ACPI_THERMAL=y
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_ONDEMAND=y
CONFIG_X86_INTEL_PSTATE=y

# 必要的存储驱动
CONFIG_ATA=y
CONFIG_ATA_ACPI=y
CONFIG_SATA_AHCI=y
CONFIG_ATA_PIIX=y
CONFIG_ATA_VERBOSE_ERROR=y
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_EXT4_FS_SECURITY=y

# 必要的块设备
CONFIG_BLK_DEV_SD=y
CONFIG_BLK_DEV_LOOP=y

# 必要的字符设备
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_HW_CONSOLE=y
CONFIG_UNIX98_PTYS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# USB（2540p 只有 USB2）
CONFIG_USB=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_UHCI_HCD=y
CONFIG_USB_STORAGE=y
CONFIG_USB_HID=y
CONFIG_HID_GENERIC=y

# 图形（i915）
CONFIG_DRM=y
CONFIG_DRM_I915=y
CONFIG_DRM_I915_GVT=n
CONFIG_DRM_I915_FORCE_PROBE=""
CONFIG_FB=y
CONFIG_FB_EFI=n
CONFIG_FB_SIMPLE=y

# 声卡（HDA Intel）
CONFIG_SND=y
CONFIG_SND_HDA=y
CONFIG_SND_HDA_INTEL=y
CONFIG_SND_HDA_CODEC_REALTEK=y
CONFIG_SND_HDA_CODEC_HDMI=y

# 有线网卡（Intel 82577LM）
CONFIG_E1000E=y

# 无线网卡（Intel Centrino Advanced-N 6200）
CONFIG_CFG80211=y
CONFIG_MAC80211=y
CONFIG_IWLWIFI=y
CONFIG_IWLWIFI_LEDS=n
CONFIG_IWLWIFI_OPMODE_MODULAR=n
CONFIG_IWLAGN=y

# 输入设备
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_KEYBOARD_ATKBD=y
CONFIG_INPUT_MOUSE=y
CONFIG_MOUSE_PS2=y

# 文件系统
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y

# 内核压缩方式（2540p 最快）
CONFIG_KERNEL_GZIP=y

# 必要的调度器
CONFIG_PREEMPT_NONE=y
CONFIG_HZ_250=y

# 禁用不必要的子系统（极限精简）
CONFIG_MODULES=n
CONFIG_NETFILTER=n
CONFIG_IPV6=n
CONFIG_BT=n
CONFIG_FIREWIRE=n
CONFIG_THUNDERBOLT=n
CONFIG_SCSI_LOWLEVEL=n
CONFIG_MEDIA_SUPPORT=n
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_BACKLIGHT_LCD_SUPPORT=y

# 调试全部关闭
CONFIG_DEBUG_KERNEL=n
CONFIG_DEBUG_INFO=n
CONFIG_KALLSYMS=n
