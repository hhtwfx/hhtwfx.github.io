vim.loader.enable()

local lazypath = vim.fn.stdpath("data").."/lazy/lazy.nvim"
if not vim.loop.fs_stat(lazypath) then
  vim.fn.system({"git","clone","--filter=blob:none","https://github.com/folke/lazy.nvim",lazypath})
end
vim.opt.rtp:prepend(lazypath)

require("lazy").setup({
  { "williamboman/mason.nvim", config = true },
  { "williamboman/mason-lspconfig.nvim" },
  { "neovim/nvim-lspconfig" },
  { "nvim-treesitter/nvim-treesitter", build=":TSUpdate" },
  { "hrsh7th/nvim-cmp" },
  { "hrsh7th/cmp-nvim-lsp" },

  -- Telescope（新增）
  { "nvim-lua/plenary.nvim" },
  { "nvim-telescope/telescope.nvim", tag="0.1.5" },
})

vim.opt.number = true
vim.opt.relativenumber = true
vim.opt.termguicolors = true

require("mason").setup()
require("mason-lspconfig").setup({ ensure_installed = { "lua_ls" } })

local cmp = require("cmp")
cmp.setup({ mapping = cmp.mapping.preset.insert(), sources = { { name="nvim_lsp" } } })

local caps = require("cmp_nvim_lsp").default_capabilities()
require("mason-lspconfig").setup_handlers({
  function(server) require("lspconfig")[server].setup({ capabilities = caps }) end
})

require("nvim-treesitter.configs").setup({ highlight={enable=true} })

-- Telescope 快捷键（新增）
local t = require("telescope.builtin")
vim.keymap.set("n", "<leader>ff", t.find_files)
vim.keymap.set("n", "<leader>fg", t.live_grep)
