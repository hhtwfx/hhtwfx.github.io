CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_X86=y
CONFIG_MMU=y
CONFIG_NO_HZ=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_GENERIC_CLOCKEVENTS=y
CONFIG_TICK_ONESHOT=y

# 必须：内核启动入口
CONFIG_EXPERT=y
CONFIG_INIT_ENV_ARG_LIMIT=32

# 必须：initramfs 支持
CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE=""
CONFIG_RD_GZIP=y

# 必须：基本文件系统
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y

# 必须：字符设备
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# 必须：打印输出
CONFIG_PRINTK=y
CONFIG_EARLY_PRINTK=y
CONFIG_EARLY_PRINTK_DBGP=y

# 必须：PCI（QEMU 默认硬件）
CONFIG_PCI=y
CONFIG_PCI_DIRECT=y

# 必须：VirtIO（QEMU 虚拟设备）
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y

# 必须：内存管理
CONFIG_SLUB=y
CONFIG_SLAB=y
CONFIG_MMU=y

# 必须：调度器
CONFIG_SCHED_CORE=y

# 必须：ELF 支持
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y

# 必须：内核压缩格式
CONFIG_KERNEL_GZIP=y

# 禁用模块（更小）
CONFIG_MODULES=n

# 禁用大部分驱动
CONFIG_NET=n
CONFIG_USB=n
CONFIG_SCSI=n
CONFIG_ATA=n
CONFIG_SOUND=n
CONFIG_INPUT=n
CONFIG_ACPI=n
CONFIG_HOTPLUG=n
CONFIG_IKCONFIG=n
CONFIG_IKCONFIG_PROC=n
